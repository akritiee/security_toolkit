# ── Copy this file to .env and fill in your real values ───────────────────
# NEVER commit your actual .env to GitHub

# VirusTotal API Key (get free at https://www.virustotal.com/gui/my-apikey)
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API Key (get free at https://www.abuseipdb.com/account/api)
ABUSEIPDB_KEY=your_abuseipdb_api_key_here

# Path to your Firebase service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_KEY_PATH=firebase-adminsdk.json
